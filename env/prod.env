# Production profile template
# Replace service URLs and origin values with production endpoints before deployment.
GATEWAY_BIND=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_REQUEST_TIMEOUT_MS=7000
GATEWAY_AUTH_TIMEOUT_MS=2000
GATEWAY_AUTH_CACHE_TTL_SECONDS=10
GATEWAY_LOGIN_RATE_LIMIT_PER_MINUTE=10
GATEWAY_MAX_BODY_BYTES=1048576
GATEWAY_CORS_ALLOWED_ORIGINS=https://app.example.com
GATEWAY_IP_GUARD_ENABLED=true
GATEWAY_ALLOWED_IPS=127.0.0.1,10.0.0.0/8
GATEWAY_IP_GUARD_DEFAULT_ALLOW=false
GATEWAY_ADMIN_IP_GUARD_ENABLED=true
GATEWAY_ADMIN_ALLOWED_IPS=127.0.0.1,10.0.0.0/8
GATEWAY_ADMIN_IP_GUARD_DEFAULT_ALLOW=false
GATEWAY_ADVANCED_ROUTE_POLICIES_ENABLED=true
GATEWAY_ADMIN_PERMISSION_CHECK_ENABLED=true
GATEWAY_PERMISSION_CACHE_ENABLED=true
GATEWAY_PERMISSION_CACHE_TTL_SECONDS=300
GATEWAY_PERMISSION_CACHE_PREFIX=gateway:admin-permission:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TIMEOUT_MS=1000
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
BLOCK_SERVICE_URL=http://localhost:8083
PERMISSION_SERVICE_URL=http://localhost:8084
AUTH_VALIDATE_URL=http://localhost:8081/auth/internal/session/validate
PERMISSION_ADMIN_VERIFY_URL=http://localhost:8084/permissions/internal/admin/verify
