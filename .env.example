# Example development profile (copy and update as needed)
GATEWAY_BIND=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_REQUEST_TIMEOUT_MS=30000
GATEWAY_AUTH_TIMEOUT_MS=3000
GATEWAY_AUTH_CACHE_TTL_SECONDS=15
GATEWAY_LOGIN_RATE_LIMIT_PER_MINUTE=20
GATEWAY_MAX_BODY_BYTES=1048576
GATEWAY_CORS_ALLOWED_ORIGINS=*
GATEWAY_IP_GUARD_ENABLED=false
GATEWAY_ALLOWED_IPS=127.0.0.1
GATEWAY_IP_GUARD_DEFAULT_ALLOW=true
GATEWAY_ADMIN_IP_GUARD_ENABLED=true
GATEWAY_ADMIN_ALLOWED_IPS=127.0.0.1,192.168.65.1
GATEWAY_ADMIN_IP_GUARD_DEFAULT_ALLOW=false
GATEWAY_ADVANCED_ROUTE_POLICIES_ENABLED=false
GATEWAY_PERMISSION_CACHE_ENABLED=false
GATEWAY_PERMISSION_CACHE_TTL_SECONDS=300
GATEWAY_PERMISSION_CACHE_PREFIX=gateway:admin-permission:
# OAuth redirect/cookie debug logs in gateway (request/response trace for SSO paths)
GATEWAY_OAUTH_DEBUG_LOG_ENABLED=false
GATEWAY_AUDIT_LOG_ENABLED=true
GATEWAY_AUDIT_LOG_PATH=./logs/audit.log
GATEWAY_AUDIT_SERVICE_NAME=api-gateway-server
GATEWAY_AUDIT_LOG_ASYNC_ENABLED=true
GATEWAY_AUDIT_LOG_ASYNC_THREADS=2
REDIS_HOST=central-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT_MS=1000
AUTH_SERVICE_URL=http://auth-service:8081
USER_SERVICE_URL=http://user-service:8082
BLOCK_SERVICE_URL=http://documents-service:8083
PERMISSION_SERVICE_URL=http://permission-service:8084
AUTH_VALIDATE_URL=http://auth-service:8081/auth/internal/session/validate

# JWT verification helpers
# HS256 example:
# - AUTH_JWT_SHARED_SECRET must match auth-service AUTH_JWT_SECRET/JWT_ACCESS_TOKEN_SECRET
# - AUTH_JWT_PUBLIC_KEY_PEM is not used for HS algorithms
AUTH_JWT_VERIFY_ENABLED=false
AUTH_JWT_PUBLIC_KEY_PEM=
AUTH_JWT_SHARED_SECRET=
AUTH_JWT_KEY_ID=
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_ISSUER=auth-service
# Optional. Leave empty unless auth-service tokens actually include an aud claim.
AUTH_JWT_AUDIENCE=
AUTH_JWT_CLOCK_SKEW_SECONDS=30
